# ── Environment ─────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Dependencies ─────────────────────────────────────────
node_modules/
vendor/
.venv/
venv/
__pycache__/
*.pyc

# ── Build outputs ────────────────────────────────────────
dist/
build/
out/
target/
*.class
*.o
*.a
*.so
*.dylib

# ── Logs ─────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Test & coverage ──────────────────────────────────────
coverage/
.nyc_output/
*.lcov
htmlcov/
.pytest_cache/

# ── IDE & OS ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.user
*.swp
*~

# ── Temp ─────────────────────────────────────────────────
tmp/
temp/
.cache/

# ── Nix / direnv / devenv ────────────────────────────────
.direnv/
.devenv/
devenv.local.nix

# ── Terraform ────────────────────────────────────────────
# .terraform.lock.hcl is intentionally NOT ignored — commit it so provider
# version/checksum selection stays reproducible across machines.
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example
