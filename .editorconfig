root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{py,java,kt,rs,c,h,cpp,hpp,cs}]
indent_size = 4

# gofmt formats with tabs, not spaces — don't fight it.
[*.go]
indent_style = tab
